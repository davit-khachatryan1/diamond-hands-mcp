# ── diamond-hands-mcp — environment variables ────────────────────────────────
# All of these are passed via Cursor's mcp.json "env" block.
# Copy this to .env for local dev/testing.

# Subgraph URL for the Diamond Hands protocol
SUBGRAPH_URL=https://api.studio.thegraph.com/query/65258/diamond-hands/v0.6.23

# Graph API key for authenticated subgraph access
GRAPH_API_KEY=your_graph_api_key_here

# Ethereum RPC URL (Sepolia)
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Private key for the SDK signer (required even for read-only SDK init)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Chain ID (supported: 1 = mainnet, 11155111 = Sepolia)
CHAIN_ID=11155111

# SDK service endpoint
SERVICE_ENDPOINT=https://diamond-hands-lit-ops-server-0d655e7f3988.herokuapp.com

# Bitcoin provider base URL or Esplora API URL
# Base form will be normalized to /api/esplora automatically
BITCOIN_PROVIDER_URL=https://dh-btc-faucet-jw-bb7756976029.herokuapp.com

# Optional provider name shown in SDK internals/logging
BITCOIN_PROVIDER_NAME=Diamond Hands

# Optional Bitcoin network (regtest, testnet, mainnet)
BITCOIN_PROVIDER_NETWORK=regtest
